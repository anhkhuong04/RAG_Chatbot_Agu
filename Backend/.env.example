# ==========================================
# RAG CHATBOT ENVIRONMENT CONFIGURATION
# Copy this file to .env and fill in your values
# ==========================================

# --- ENVIRONMENT ---
ENVIRONMENT=development  # development, production

# --- API KEYS (REQUIRED) ---
GOOGLE_API_KEY=your_google_api_key_here
LLAMA_CLOUD_API_KEY=your_llama_cloud_api_key_here

# --- LLM & EMBEDDING (Optional - has defaults) ---
# LLM_MODEL=models/gemini-2.5-flash
# EMBEDDING_MODEL=models/text-embedding-004

# --- QUERY TRANSFORMATION ---
USE_QUERY_TRANSFORMATION=true
QUERY_TRANSFORM_STRATEGY=rewrite  # rewrite, decompose, multi_query, hyde, full

# --- RETRIEVAL ---
RETRIEVAL_TOP_K=8
SIMILARITY_TOP_K=5

# --- RE-RANKING ---
USE_RERANKING=true
RERANKER_TYPE=cross-encoder  # cross-encoder, llm, cohere, none
RERANKER_MODEL=multilingual-large  # multilingual-large, multilingual-small, english-large
RERANKER_TOP_N=5
# COHERE_API_KEY=your_cohere_key  # Only if using cohere reranker

# --- LOGGING ---
LOG_LEVEL=INFO  # DEBUG, INFO, WARNING, ERROR
LOG_FILE=logs/app.log
LOG_TO_CONSOLE=true
LOG_MAX_BYTES=10485760  # 10MB
LOG_BACKUP_COUNT=5

# --- METRICS ---
METRICS_ENABLED=true
METRICS_RETENTION_HOURS=24

# --- REDIS CACHE (Optional) ---
REDIS_ENABLED=false
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_DB=0
REDIS_PASSWORD=
REDIS_TTL=3600  # 1 hour
REDIS_TRANSFORM_TTL=3600
REDIS_RETRIEVAL_TTL=1800
REDIS_RESPONSE_TTL=7200

# --- SESSION MANAGEMENT ---
SESSION_TTL_MINUTES=60
MEMORY_TOKEN_LIMIT=3000
MAX_SESSIONS=1000

# --- RATE LIMITING ---
RATE_LIMIT_ENABLED=true
RATE_LIMIT_PER_MINUTE=30
RATE_LIMIT_PER_HOUR=500
RATE_LIMIT_BURST=5

# --- QDRANT (For production) ---
# QDRANT_URL=https://your-qdrant-cloud-url
# QDRANT_API_KEY=your_qdrant_api_key
